# Discord / runtime
DISCORD_TOKEN=
PRIMARY_SELFBOT_NAME=Primary Selfbot
HOST_PORT=3099
PORT=3099
TZ=Europe/Vienna
DATA_FILE=/app/examples/control-panel/data/control-panel-state.json
SELFBOT_CONFIG_FILE=/app/examples/control-panel/data/selfbot-profiles.tsv

# Commands / optional control bot
DISCORD_COMMANDS_ENABLED=1
COMMAND_PREFIX=$panel
COMMAND_PREFIX_ALIASES=
CONTROL_BOT_TOKEN=
CONTROL_BOT_COMMAND_GUILD_IDS=
COMMAND_ALLOWED_AUTHOR_IDS=

# Selfbot presence
# Presence status: online | idle | dnd | invisible
# Activity type: PLAYING | STREAMING | LISTENING | WATCHING | COMPETING
IDLE_PRESENCE_STATUS=online
IDLE_ACTIVITY_TYPE=WATCHING
IDLE_ACTIVITY_TEXT=THE LION SQUAD - eSPORTS
STREAM_PRESENCE_STATUS=online
STREAM_ACTIVITY_TYPE=PLAYING
STREAM_ACTIVITY_TEXT={{title}}
VOICE_STATUS_TEMPLATE=Now streaming: {{title}}

# Panel auth
PANEL_AUTH_ENABLED=0
PANEL_AUTH_USERNAME=
PANEL_AUTH_PASSWORD=
PANEL_AUTH_REALM=Stream Bot

# yt-dlp / YouTube
YT_DLP_COOKIES_FROM_BROWSER=
YT_DLP_COOKIES_FILE=
YT_DLP_YOUTUBE_EXTRACTOR_ARGS=youtube:player_client=android
YT_DLP_PACKAGE=yt-dlp[default]
YT_DLP_FORMAT=bestvideo[vcodec!=none]+bestaudio[acodec!=none]/best[vcodec!=none][acodec!=none]/best*[vcodec!=none][acodec!=none]/best

# Performance / scheduler
# Preferred encoder: auto | nvenc | vaapi
PREFERRED_HW_ENCODER=auto
FFMPEG_VAAPI_DEVICE=/dev/dri/renderD128
FFMPEG_LOG_LEVEL=warning
SCHEDULER_POLL_MS=1000
STARTUP_TIMEOUT_MS=15000

# Optional bootstrap defaults for notifications.
# These values are only used until notification settings were saved in the panel state.
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_DM_ENABLED=0
